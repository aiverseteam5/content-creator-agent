# ============================================================
# Content Creator AI Agent — Environment Variables
# ============================================================
# Copy this file to .env and fill in your actual values:
#   cp .env.example .env
# ============================================================

# === Database ===
DATABASE_URL=postgresql+asyncpg://agent:changeme@localhost:5432/content_agent
DB_PASSWORD=changeme

# === Redis ===
REDIS_URL=redis://localhost:6379/0

# === Anthropic (Claude) ===
ANTHROPIC_API_KEY=sk-ant-...
DEFAULT_MODEL=claude-sonnet-4-20250514
PREMIUM_MODEL=claude-opus-4-6

# === Slack (Socket Mode — no public URL needed) ===
SLACK_BOT_TOKEN=xoxb-...
SLACK_SIGNING_SECRET=...
SLACK_APP_TOKEN=xapp-...
SLACK_CHANNEL_ID=C0123456789

# === LinkedIn (OAuth 2.0 — 3-legged) ===
LINKEDIN_CLIENT_ID=...
LINKEDIN_CLIENT_SECRET=...
LINKEDIN_ACCESS_TOKEN=...
LINKEDIN_REFRESH_TOKEN=...
LINKEDIN_PERSON_URN=urn:li:person:...

# === X/Twitter (OAuth 2.0 PKCE) ===
TWITTER_API_KEY=...
TWITTER_API_SECRET=...
TWITTER_ACCESS_TOKEN=...
TWITTER_ACCESS_TOKEN_SECRET=...
TWITTER_BEARER_TOKEN=...

# === Reddit ===
REDDIT_CLIENT_ID=...
REDDIT_CLIENT_SECRET=...
REDDIT_USER_AGENT=content-creator-agent/1.0

# === Web Search (Tavily) ===
TAVILY_API_KEY=tvly-...

# === Embeddings (Voyage AI) ===
VOYAGE_API_KEY=...

# === Scheduling ===
RESEARCH_INTERVAL_HOURS=4
ANALYTICS_DELAY_HOURS=24
USER_TIMEZONE=Asia/Kolkata

# === App Settings ===
LOG_LEVEL=INFO
ENVIRONMENT=development
